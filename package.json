{
  "name": "3d-model-viewer",
  "version": "1.0.0",
  "description": "Reusable, batteries-included 3D IFC Model Viewer as an embeddable JavaScript component",
  "main": "dist/model-viewer.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:old": "vite --open /old.html",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx playwright test",
    "test:selection": "npx playwright test evals/tests/selection.spec.js",
    "test:search-sets": "npx playwright test evals/tests/search-sets.spec.js",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report evals/report"
  },
  "dependencies": {
    "@thatopen/components": "^2.4.0",
    "@thatopen/fragments": "^3.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.175.0",
    "web-ifc": "0.0.68"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.0.0"
  },
  "keywords": [
    "ifc",
    "bim",
    "3d",
    "viewer",
    "three.js",
    "building"
  ],
  "license": "MIT"
}
